{
  "@context": {
    "@vocab": "https://schema.org/",
    "inspector": "https://docs.aws.amazon.com/inspector/v2/APIReference/",
    "aws": "https://aws.amazon.com/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Finding": {
      "@id": "inspector:API_Finding",
      "@context": {
        "findingArn": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "severity": {
          "@id": "inspector:severity",
          "@type": "xsd:string"
        },
        "status": {
          "@id": "inspector:findingStatus",
          "@type": "xsd:string"
        },
        "type": {
          "@id": "inspector:findingType",
          "@type": "xsd:string"
        },
        "title": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "awsAccountId": {
          "@id": "inspector:awsAccountId",
          "@type": "xsd:string"
        },
        "firstObservedAt": {
          "@id": "schema:dateCreated",
          "@type": "xsd:dateTime"
        },
        "lastObservedAt": {
          "@id": "schema:dateModified",
          "@type": "xsd:dateTime"
        },
        "inspectorScore": {
          "@id": "inspector:inspectorScore",
          "@type": "xsd:decimal"
        },
        "resources": {
          "@id": "inspector:affectedResources",
          "@container": "@list"
        },
        "remediation": {
          "@id": "inspector:remediation",
          "@type": "inspector:Remediation"
        }
      }
    },

    "Resource": {
      "@id": "inspector:AffectedResource",
      "@context": {
        "id": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "type": {
          "@id": "inspector:resourceType",
          "@type": "xsd:string"
        },
        "region": {
          "@id": "inspector:awsRegion",
          "@type": "xsd:string"
        },
        "tags": {
          "@id": "schema:keywords",
          "@container": "@index"
        }
      }
    },

    "Vulnerability": {
      "@id": "inspector:PackageVulnerability",
      "@context": {
        "vulnerabilityId": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "source": {
          "@id": "inspector:vulnerabilitySource",
          "@type": "xsd:string"
        },
        "sourceUrl": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "cvss": {
          "@id": "inspector:cvssScores",
          "@container": "@list"
        },
        "vulnerablePackages": {
          "@id": "inspector:vulnerablePackages",
          "@container": "@list"
        }
      }
    },

    "Filter": {
      "@id": "inspector:API_Filter",
      "@context": {
        "arn": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "action": {
          "@id": "inspector:filterAction",
          "@type": "xsd:string"
        },
        "criteria": {
          "@id": "inspector:filterCriteria",
          "@type": "inspector:FilterCriteria"
        }
      }
    }
  }
}
