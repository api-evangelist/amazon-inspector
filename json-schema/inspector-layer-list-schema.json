  "title": "LayerList",
  "description": "LayerList schema",
  "type": "array",
  "items": {
    "type": "string",
    "pattern": "^arn:[a-zA-Z0-9-]+:lambda:[a-zA-Z0-9-]+:\\d{12}:layer:[a-zA-Z0-9-_]+:[0-9]+$"
